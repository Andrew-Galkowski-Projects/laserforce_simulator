# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Django stuff: local DB, media, static files (optional)
# ignore database file in project root (keep this explicit)
/db.sqlite3
*.sqlite3
# WAL journal-mode sidecar files (not matched by *.sqlite3)
*.sqlite3-wal
*.sqlite3-shm
media/

# VSCode settings
.vscode/

# Local virtual environment
.venv/

# Environment variable files — never commit real secrets
.env
*.env.local

# Generated by collectstatic — rebuilt by Docker/CI
staticfiles/
