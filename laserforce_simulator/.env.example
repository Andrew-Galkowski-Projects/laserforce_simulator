SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite is used locally when DATABASE_URL is unset.
# Set this to a PostgreSQL URL in production (see DEPLOY-05).
DATABASE_URL=postgres://user:password@host:5432/dbname

# Cloudflare R2 credentials (see DEPLOY-04)
R2_BUCKET_NAME=your-bucket-name
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Optional: public URL for serving media files (custom domain or R2 public bucket URL).
# Enable "Allow Public Access" in the Cloudflare dashboard, then set this to the
# resulting URL (e.g. https://pub-<hash>.r2.dev or your custom domain).
# If unset, MEDIA_URL falls back to the S3 API endpoint which may not serve files publicly.
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
